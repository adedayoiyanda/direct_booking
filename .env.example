# ─────────────────────────────────────────────────────────────────────────────
# .env.example  |  Copy to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_key_here   # Settings > API > service_role (secret)
SUPABASE_ANON_KEY=your_key_here      # Settings > API > anon / public

# ── Paystack ─────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=your_key_here
PAYSTACK_WEBHOOK_SECRET=your_key_here   # From Paystack dashboard

# ── Resend (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=your_key_here
EMAIL_FROM=PayVerify <onboarding@resend.dev>   # Must match a verified domain in Resend

# ── Admin credentials ─────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=1234
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_SECRET_TOKEN=your_64_char_random_hex_string_here

# ── App ────────────────────────────────────────────────────────────────────────
DEBUG=False
ALLOWED_ORIGINS=["https://yourdomain.com","http://localhost:8000"]
